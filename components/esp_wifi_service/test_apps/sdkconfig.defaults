CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_TASK_WDT_INIT=n
CONFIG_ESP_MAIN_TASK_STACK_SIZE=35840
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096

CONFIG_UNITY_ENABLE_BACKTRACE_ON_FAIL=y
CONFIG_UNITY_ENABLE_64BIT=y

# Keep the default test app on local, unattended paths only.
CONFIG_WIFI_SERVICE_PROV_HTTP_ENABLE=n
CONFIG_WIFI_SERVICE_PROV_BLUFI_ENABLE=n
CONFIG_WIFI_SERVICE_SELECTOR_PROBE_ENABLE=n
CONFIG_WIFI_SERVICE_SELECTOR_THROUGHPUT_ENABLE=n
CONFIG_ESP_MCP_ENABLE=n
CONFIG_WIFI_SERVICE_TEST_WITH_SSID=n
