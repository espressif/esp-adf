# Serial flasher
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
# ADF uses pre-v8 FreeRTOS type names (xSemaphoreHandle, xTimerHandle, etc.)
CONFIG_FREERTOS_ENABLE_BACKWARD_COMPATIBILITY=y

# FAT filesystem
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_API_ENCODING_UTF_8=y

# OTA service
CONFIG_OTA_FORCE_VERSION_CHECK=n

# Disable esp_service MCP layer (not needed for this test)
CONFIG_ESP_MCP_ENABLE=n
CONFIG_OTA_ENABLE_ROLLBACK=y
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
